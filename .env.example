# ── The Odds API ──────────────────────────────────────────────────────────
ODDS_API_KEY=sua_chave_aqui

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=nba_scout
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nba_scout

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Observabilidade ───────────────────────────────────────────────────────
SENTRY_DSN=
# Amostragem de traces do Sentry (0.0 = só erros; ex.: 0.1 = 10% das requests)
SENTRY_TRACES_SAMPLE_RATE=0.0
# Grafana (compose.observability.yml) — troque em produção
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── App ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Proxy (para geoblock do stats.nba.com em servidor cloud) ──────────────
# HTTPS_PROXY=http://proxy:port
